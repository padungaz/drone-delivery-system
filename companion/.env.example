# Drone Delivery Companion — Environment Configuration
# Copy to .env and edit values before running:
#   cp .env.example .env
#   nano .env

# -------------------------------------------------------
# Network — LAN IP of the FastAPI backend server (Laptop)
# -------------------------------------------------------
SERVER_IP=192.168.137.1
SERVER_PORT=8000
DRONE_ID=drone-01

# -------------------------------------------------------
# MAVLink — UART connection to Pixhawk 6C
#   /dev/ttyAMA0  → Pi GPIO UART (Pixhawk TELEM1, recommended)
#   /dev/ttyUSB0  → USB-Serial adapter
# Baudrate: 57600 or 921600 (recommended)
# -------------------------------------------------------
MAVLINK_DEVICE=/dev/ttyAMA0
MAVLINK_BAUD=921600


# -------------------------------------------------------
# Camera
#   csi    → CSI camera via picamera2 (Raspberry Pi Camera Module)
#   webcam → USB webcam
# -------------------------------------------------------
CAMERA_BACKEND=csi
CAMERA_WEBCAM_INDEX=0

# -------------------------------------------------------
# Logging
#   LOG_FILE: path to log file (leave empty for stdout only)
#   LOG_LEVEL: DEBUG | INFO | WARNING | ERROR
# -------------------------------------------------------
LOG_FILE=/var/log/drone-companion.log
LOG_LEVEL=INFO

# -------------------------------------------------------
# Mission parameters (optional override)
# -------------------------------------------------------
TAKEOFF_ALTITUDE_M=10.0
RTL_ALTITUDE_M=30.0
DESCEND_ALTITUDE_M=10.0
