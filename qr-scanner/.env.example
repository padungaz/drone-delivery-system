# ===========================================
# QR Scanner Station — Environment Variables
# ===========================================

# Backend server IP address (LAN)
SERVER_IP=192.168.137.1

# Backend server port
SERVER_PORT=8000

# USB camera index (0 = default camera)
CAMERA_INDEX=0

# Camera resolution
CAMERA_WIDTH=640
CAMERA_HEIGHT=480
CAMERA_FPS=30

# Debounce: thời gian tối thiểu giữa 2 lần gửi cùng 1 QR (giây)
SCAN_DEBOUNCE_SEC=5.0

# Thời gian xóa cache debounce (giây)
SCAN_CACHE_TTL_SEC=30.0

# WebSocket reconnect delay (giây)
WS_RECONNECT_DELAY_SEC=3.0

# Hiển thị cửa sổ camera preview (true/false)
SHOW_PREVIEW=true
